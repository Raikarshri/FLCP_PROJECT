# Supabase PostgreSQL connection string
# Example:
# postgresql://postgres.[project-ref]:[password]@[host]:6543/postgres
SUPABASE_DB_URL=

# Postgres SSL mode for Supabase
DATABASE_SSLMODE=require

# App secrets
JWT_SECRET_KEY=e01c4d6ee362ad87631c5dc0b12d53d44596afa578bbc97572e76532968c6a88
FLASK_SECRET_KEY=e01c4d6ee362ad87631c5dc0b12d53d44596afa578bbc97572e76532968c6a88

# Cookie setting
# Use true in production with HTTPS
COOKIE_SECURE=false

# JWT lifetime in hours
JWT_EXP_HOURS=12

# Optional fallback database URL if SUPABASE_DB_URL is not set
# DATABASE_URL=sqlite:///flcp_app.db
